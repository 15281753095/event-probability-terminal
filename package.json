{
  "name": "event-probability-terminal",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "pnpm dev:web",
    "dev:web": "pnpm --filter @ept/web dev",
    "dev:api": "pnpm --filter @ept/api-gateway dev",
    "dev:pricing": "PYTHONPATH=services/pricing-engine/src .venv/bin/python -m pricing_engine.main --healthz",
    "build": "pnpm -r build",
    "check": "pnpm typecheck && pnpm build && pnpm test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "lint:python": ".venv/bin/python -m ruff check services/pricing-engine && .venv/bin/python -m mypy services/pricing-engine/src",
    "test": "pnpm test:js && pnpm test:python",
    "test:js": "pnpm -r test",
    "test:python": "PYTHONPATH=services/pricing-engine/src .venv/bin/python -m pytest services/pricing-engine/tests",
    "test:smoke": "pnpm --filter @ept/web test:smoke",
    "test:smoke:install": "pnpm --filter @ept/web exec playwright install chromium",
    "capture:snapshot": "pnpm --filter @ept/research-signals capture:snapshot",
    "capture:once": "pnpm --filter @ept/research-signals capture:once",
    "capture:binance": "pnpm --filter @ept/research-signals capture:binance",
    "capture:polymarket": "pnpm --filter @ept/research-signals capture:polymarket",
    "capture:fair-value": "pnpm --filter @ept/research-signals capture:fair-value",
    "capture:replay": "pnpm --filter @ept/research-signals capture:replay",
    "capture:strategy-lab": "pnpm --filter @ept/research-signals capture:strategy-lab",
    "store:status": "pnpm --filter @ept/research-signals store:status"
  }
}

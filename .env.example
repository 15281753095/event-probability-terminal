# Runtime ports
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
API_GATEWAY_PORT=4000
API_GATEWAY_HOST=0.0.0.0

# Local infrastructure
POSTGRES_PORT=5432
REDIS_PORT=6379
POSTGRES_USER=ept
POSTGRES_PASSWORD=ept
POSTGRES_DB=ept
DATABASE_URL=postgresql://ept:ept@localhost:5432/ept
REDIS_URL=redis://localhost:6379/0

# Polymarket public-read configuration. No API keys are required for these public endpoints.
POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com
POLYMARKET_USE_FIXTURES=true

# External API secrets are intentionally omitted. Phase 1 forbids authenticated trading.
